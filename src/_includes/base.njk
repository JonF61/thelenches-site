<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta name="google-site-verification" content="tZwnp0H9L9izwMlQb5imWeptFYtCY3UstxkKAWSvj38" />
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:wght@600;700&family=Work+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  {% if site.noindex %}<meta name="robots" content="noindex, nofollow">{% endif %}
  <title>{{ title }} — The Lenches</title>
  {% if description %}<meta name="description" content="{{ description }}">{% endif %}
  <link rel="stylesheet" href="{{ '/style.css' | url }}">
  {% if page.url == "/" %}<link rel="preload" as="image" href="{{ '/images/club-view.jpg' | url }}" fetchpriority="high">{% endif %}
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>

  <header class="site-header">
    <div class="container">
      <a class="brand" href="{{ '/' | url }}">The Lenches <span>&middot; {{ site.region }}</span></a>
      <nav class="nav" aria-label="Main">
        {% for item in site.nav %}
        <a href="{{ item.url | url }}"{% if page.url == item.url %} class="active" aria-current="page"{% endif %}>{{ item.title }}</a>
        {% endfor %}
      </nav>
    </div>
  </header>

  <div id="main" tabindex="-1">{{ content | safe }}</div>

  <footer class="site-footer">
    <div class="container">
      <div>
        <strong>The Lenches Newsletter</strong><br>
        <a href="mailto:{{ site.email }}">{{ site.email }}</a>
      </div>
      <div>
        {% for item in site.nav %}{% if not loop.first %} &middot; {% endif %}<a href="{{ item.url | url }}">{{ item.title }}</a>{% endfor %} &middot; <a href="{{ '/privacy/' | url }}">Privacy</a>
      </div>
    </div>
    <div class="container">
      <p class="disclaimer">Information on this website is provided by third parties and, while we try to keep it accurate and up to date, it may not always be. Spotted something wrong? Let us know.</p>
    </div>
  </footer>

</body>
</html>
