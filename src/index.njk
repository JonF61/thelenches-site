               style="padding:.6rem .8rem;border:1px solid var(--line);border-radius:6px;min-width:240px;font-size:1rem;margin:.25rem .5rem .25rem 0;">
        <input type="hidden" name="ml-submit" value="1">
        <button type="submit" class="btn">Subscribe</button>
      </form>
      <p class="ml-thanks small" style="display:none;color:var(--green-dark);font-weight:600;margin-top:.8rem;">Thanks — please check your inbox to confirm your subscription.</p>
